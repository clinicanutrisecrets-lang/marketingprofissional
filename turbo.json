{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_SERVICE_ROLE_KEY",
        "ANTHROPIC_API_KEY",
        "META_APP_ID",
        "META_APP_SECRET",
        "META_REDIRECT_URI",
        "BANNERBEAR_API_KEY",
        "BANNERBEAR_PROJECT_ID",
        "BANNERBEAR_TEMPLATE_FEED_IMAGEM",
        "BANNERBEAR_TEMPLATE_REELS_COVER",
        "BANNERBEAR_TEMPLATE_CARROSSEL",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "HEYGEN_API_KEY",
        "ENCRYPTION_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
