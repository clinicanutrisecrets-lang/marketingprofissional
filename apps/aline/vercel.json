{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=aline",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/publicar",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/gerar-pack-semanal",
      "schedule": "0 12 * * 4"
    }
  ]
}
