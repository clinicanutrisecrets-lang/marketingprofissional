# ============================================================
# WHATSAPP BOT — Studio Aline
# Copie para .env e preencha.
# ============================================================

# Anthropic (Claude Sonnet 4.6 como padrão)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gamma (API Key em gamma.app → Workspace Settings → API)
GAMMA_API_KEY=sk-gamma-...
# Tema "Scanner" já existe na conta da Aline. Troque se quiser outro.
GAMMA_THEME_ID=xorjxo3seh6pyiu

# WhatsApp — ID do grupo. Rode `pnpm list-groups` depois de escanear o QR
# pra descobrir. Formato: 120363XXXXXXXXXXX@g.us
WHATSAPP_GROUP_ID=

# Janela de envio (horário local). O bot sorteia dia+hora dentro dela.
SEND_WINDOW_START_HOUR=9
SEND_WINDOW_END_HOUR=19
# Intervalo mínimo e máximo entre envios (dias). Gera jitter pra não
# parecer robô. Padrão 3 dias ± 1.
SEND_INTERVAL_MIN_DAYS=2
SEND_INTERVAL_MAX_DAYS=4

# NCBI (PubMed) — email obrigatório pela política da Entrez. Chave opcional
# (aumenta rate limit de 3 → 10 req/s). Pegar em https://account.ncbi.nlm.nih.gov.
NCBI_EMAIL=aline@scannerdasaude.com
NCBI_API_KEY=

# Timezone pra o cron (IANA)
TZ=America/Sao_Paulo
