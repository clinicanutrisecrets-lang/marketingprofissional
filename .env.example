# ============================================================
# MARKETING PROFISSIONAL — MONOREPO
# Scanner da Saúde Franquia + Studio Aline
# ============================================================
# Copie para .env.local em cada app e preencha os valores.
# Na Vercel, adicione em Settings → Environment Variables dos 2 projetos.

# ============================================================
# SUPABASE (compartilhado — mesmo projeto, schemas separados)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://mfldshdxulqxskwcoxrl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_f_B21kGZx3mnTjHPDJ5svQ_L0SMaVFv
SUPABASE_SERVICE_ROLE_KEY=  # Pegar em Supabase → Settings → API → service_role

# ============================================================
# ANTHROPIC (compartilhado — 1 key master)
# ============================================================
ANTHROPIC_API_KEY=  # sk-ant-api03-... (gerar em console.anthropic.com)

# ============================================================
# META (compartilhado — 1 app, 2 contextos de uso)
# ============================================================
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI_FRANQUIAS=https://marketingprofissional.vercel.app/api/auth/meta/callback
META_REDIRECT_URI_ALINE=https://studio-aline.vercel.app/api/auth/meta/callback

# Pixel unico da marca Scanner da Saude — dispara na LP /nutri/[slug]
# Eventos: PageView (auto), ViewContent (scroll >50%), Lead (click WhatsApp)
# ID em business.facebook.com → Events Manager → Data Sources
NEXT_PUBLIC_META_PIXEL_ID=

# Conversions API (server-side) — dispara Schedule R$650 e Purchase R$1800
# META_PIXEL_ID = mesmo valor de NEXT_PUBLIC_META_PIXEL_ID (so facilita leitura server)
# META_CAPI_ACCESS_TOKEN = gere em Events Manager → seu Pixel → Settings → Generate Access Token
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Kiwify webhook — dispara Purchase pro CAPI quando compra e aprovada
# Gerar secret em painel Kiwify → Webhooks. Recomendado: random 64 chars.
KIWIFY_WEBHOOK_SECRET=

# Sofia (WhatsApp IA) — endpoint /api/conversions/schedule autentica com este token
# quando Sofia marca um agendamento confirmado (dispara CAPI Schedule R$650)
SOFIA_INTERNAL_TOKEN=

# ============================================================
# AI IMAGE — Geração de imagens (feed, carrossel, stories)
# ============================================================
# Substitui Bannerbear. Creatomate segue apenas para vídeo/reels.
# Studio Aline usa OpenAI (qualidade premium).
# Franquias usam Gemini (custo viável em escala).
OPENAI_API_KEY=    # platform.openai.com/api-keys
GEMINI_API_KEY=    # aistudio.google.com/app/apikey

# ============================================================
# BANNERBEAR (LEGADO — a aposentar)
# ============================================================
# Mantém só enquanto a migração pra @scanner/ai-image roda em
# paralelo. Após 1 semana de validação, cancela no Bannerbear e
# remove estas vars + o pacote packages/bannerbear.
BANNERBEAR_API_KEY=
BANNERBEAR_PROJECT_ID=
BANNERBEAR_TEMPLATE_FEED_IMAGEM=
BANNERBEAR_TEMPLATE_REELS_COVER=
BANNERBEAR_TEMPLATE_CARROSSEL=

# ============================================================
# RESEND (compartilhado)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=contato@scannerdasaude.com

# ============================================================
# HEYGEN (APENAS apps/aline — uso pessoal)
# ============================================================
# No plano Creator, API não está disponível — fluxo manual.
# Upgrade pra API plan ($99/mês) habilita integração programática.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
HEYGEN_API_ENABLED=false  # true quando fizer upgrade

# ============================================================
# SEGURANÇA
# ============================================================
ENCRYPTION_KEY=  # 32 bytes em base64: openssl rand -base64 32

# ============================================================
# URLs
# ============================================================
NEXT_PUBLIC_APP_URL_FRANQUIAS=http://localhost:3000
NEXT_PUBLIC_APP_URL_ALINE=http://localhost:3001
